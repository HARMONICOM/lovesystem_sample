{
    "event_id": "shiori_male_random_station",
    "title_ja": "駅で鉢合わせ",
    "title_en": "Bumping Into Her at the Station",
    "character_id": "shiori_nagayama",
    "scenes": [
        {
            "scene_id": "scene_001",
            "type": "dialogue",
            "text_ja": "駅前で永山さんにばったり出会った。",
            "text_en": "I ran into Nagayama-san in front of the station."
        },
        {
            "scene_id": "scene_002",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.normal",
            "text_ja": "あれ、{{player.family_name}}くん。",
            "text_en": "Oh, {{player.family_name}}."
        },
        {
            "scene_id": "scene_003",
            "type": "dialogue",
            "character": "player",
            "text_ja": "永山さん。今日はお仕事終わりですか？",
            "text_en": "Nagayama-san. Heading home from work?"
        },
        {
            "scene_id": "scene_004",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.smile",
            "text_ja": "うん。これから帰るとこ。",
            "text_en": "Yeah, I'm on my way home now."
        },
        {
            "scene_id": "scene_005",
            "type": "dialogue",
            "character": "player",
            "text_ja": "お疲れさまです。",
            "text_en": "You must be tired."
        },
        {
            "scene_id": "scene_006",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.normal",
            "text_ja": "ありがとう。",
            "text_en": "Thanks."
        },
        {
            "scene_id": "scene_007",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.smile",
            "text_ja": "なんか、こういうの好きだな。偶然ばったりって感じ。",
            "text_en": "I kind of like this. Just bumping into each other by chance."
        },
        {
            "scene_id": "scene_008",
            "type": "dialogue",
            "character": "player",
            "text_ja": "そうですね。",
            "text_en": "Yeah, me too."
        },
        {
            "scene_id": "scene_009",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.normal",
            "text_ja": "じゃ、またね。",
            "text_en": "Well, see you."
        },
        {
            "scene_id": "scene_010",
            "type": "dialogue",
            "character": "player",
            "text_ja": "（短い時間だったけど、悪くなかった。）",
            "text_en": "(...It was brief, but not bad at all.)"
        },
        {
            "scene_id": "scene_011",
            "type": "end",
            "stat_changes": {
                "affection": 2,
                "intimacy": 2
            }
        }
    ]
