{
    "event_id": "shiori_male_closer_feelings",
    "title_ja": "心の距離が縮まる",
    "title_en": "Growing Closer",
    "character_id": "shiori_nagayama",
    "scenes": [
        {
            "scene_id": "scene_001",
            "type": "dialogue",
            "character": "player",
            "text_ja": "（あ、永山さんからメッセージだ。）",
            "text_en": "(Oh, a message from Nagayama-san.)"
        },
        {
            "scene_id": "scene_002",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "text_ja": "今日、時間ある？散歩でもしたくて。",
            "text_en": "Are you free today? I feel like going for a walk."
        },
        {
            "scene_id": "scene_003",
            "type": "dialogue",
            "character": "player",
            "text_ja": "ありますよ。どこかで落ち合いますか？",
            "text_en": "Sure, I'm free. Shall we meet somewhere?"
        },
        {
            "scene_id": "scene_004",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "text_ja": "河川敷でどうかな。",
            "text_en": "How about the riverside?"
        },
        {
            "scene_id": "scene_005",
            "type": "dialogue",
            "character": "player",
            "text_ja": "（OK、と。よし、河川敷に行こう。）",
            "text_en": "(Okay then. Off to the riverside.)"
        },
        {
            "scene_id": "scene_006",
            "type": "location_change",
            "location": "riverside"
        },
        {
            "scene_id": "scene_007",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.normal",
            "text_ja": "ごめんね。わざわざ来てもらっちゃって。",
            "text_en": "Sorry. Making you come all the way out here."
        },
        {
            "scene_id": "scene_008",
            "type": "dialogue",
            "text_ja": "二人で並んで河川敷を歩いた。川沿いの空気は穏やかだった。",
            "text_en": "We walked side by side along the riverside. The air by the river was calm."
        },
        {
            "scene_id": "scene_009",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.normal",
            "text_ja": "なんか最近、仕事が立て込んでて、外の空気吸いたくて。",
            "text_en": "Work has been piling up lately. I just needed to breathe some fresh air."
        },
        {
            "scene_id": "scene_010",
            "type": "dialogue",
            "character": "player",
            "text_ja": "それは大変でしたね。",
            "text_en": "That sounds rough."
        },
        {
            "scene_id": "scene_011",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.smile",
            "text_ja": "でも、{{player.family_name}}くんと会うといつも気が楽になるんだよね。",
            "text_en": "But whenever I meet up with you, {{player.family_name}}, I always feel at ease."
        },
        {
            "scene_id": "scene_012",
            "type": "dialogue",
            "character": "player",
            "text_ja": "そうですか？",
            "text_en": "Really?"
        },
        {
            "scene_id": "scene_013",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.normal",
            "text_ja": "うん。なんか、ちゃんとそこにいてくれる感じがして。",
            "text_en": "Yeah. It feels like you're really present. Actually there."
        },
        {
            "scene_id": "scene_014",
            "type": "dialogue",
            "character": "player",
            "text_ja": "（ちゃんとそこにいてくれる、か...）",
            "text_en": "(...Really there, huh...)"
        },
        {
            "scene_id": "scene_015",
            "type": "character_hide",
            "character": "shiori_nagayama"
        },
        {
            "scene_id": "scene_016",
            "type": "image",
            "cg": "shiori_riverside"
        },
        {
            "scene_id": "scene_017",
            "type": "dialogue",
            "text_ja": "しばらく歩いて、二人でベンチに腰を下ろした。",
            "text_en": "After a while of walking, we sat down on a bench together."
        },
        {
            "scene_id": "scene_018",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "text_ja": "{{player.family_name}}くんって、悩んでることとかあったりする？",
            "text_en": "Do you have things you worry about, {{player.family_name}}?"
        },
        {
            "scene_id": "scene_019",
            "type": "dialogue",
            "character": "player",
            "text_ja": "あります、普通に。",
            "text_en": "Sure, the usual things."
        },
        {
            "scene_id": "scene_020",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "text_ja": "なんかほっとした。私だけじゃないんだって思えて。",
            "text_en": "That's reassuring. Makes me feel like I'm not alone."
        },
        {
            "scene_id": "scene_021",
            "type": "dialogue",
            "character": "player",
            "text_ja": "永山さんでも悩みますよね。",
            "text_en": "Even you worry, Nagayama-san."
        },
        {
            "scene_id": "scene_022",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "text_ja": "そりゃ悩むよ。仕事のことも、自分のこともいろいろと。",
            "text_en": "Of course I do. About work, about myself, all sorts of things."
        },
        {
            "scene_id": "scene_023",
            "type": "dialogue",
            "character": "player",
            "text_ja": "たとえばどんな？",
            "text_en": "Like what, for example?"
        },
        {
            "scene_id": "scene_024",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "text_ja": "...私って、人の前では割と明るくしてるじゃない？",
            "text_en": "...I put on a pretty cheerful front around people, right?"
        },
        {
            "scene_id": "scene_025",
            "type": "dialogue",
            "character": "player",
            "text_ja": "そうですね。",
            "text_en": "Yeah, you do."
        },
        {
            "scene_id": "scene_026",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "text_ja": "でも、正直、それで全部大丈夫なわけじゃなくて。たまに、ひとりになるのが怖くなるときがあって。",
            "text_en": "But honestly, that doesn't mean everything's fine. Sometimes I'm afraid of being alone."
        },
        {
            "scene_id": "scene_027",
            "type": "dialogue",
            "character": "player",
            "text_ja": "...",
            "text_en": "..."
        },
        {
            "scene_id": "scene_028",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "text_ja": "一人暮らしで、実家も遠いし、仕事は好きだけど。ときどき、誰かにそばにいてほしいって思う。",
            "text_en": "I live alone, my family is far away, I love my work, but... sometimes I just want someone to be near."
        },
        {
            "scene_id": "scene_029",
            "type": "dialogue",
            "character": "player",
            "text_ja": "（こんな話を俺にしてくれるんだな。）",
            "text_en": "(...She's sharing this with me.)"
        },
        {
            "scene_id": "scene_030",
            "type": "dialogue",
            "character": "player",
            "text_ja": "今、誰かいますよ。",
            "text_en": "There's someone here right now."
        },
        {
            "scene_id": "scene_031",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "text_ja": "え？",
            "text_en": "Hm?"
        },
        {
            "scene_id": "scene_032",
            "type": "dialogue",
            "character": "player",
            "text_ja": "俺が、ここにいますよ。",
            "text_en": "I'm here."
        },
        {
            "scene_id": "scene_033",
            "type": "dialogue",
            "text_ja": "しばらく間があった。",
            "text_en": "A moment of silence passed."
        },
        {
            "scene_id": "scene_034",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "text_ja": "...なんかずるいね、そういう言い方。",
            "text_en": "...That's not fair, saying it like that."
        },
        {
            "scene_id": "scene_035",
            "type": "dialogue",
            "character": "player",
            "text_ja": "ずるいですか？",
            "text_en": "Not fair?"
        },
        {
            "scene_id": "scene_036",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "text_ja": "うん。でも、嬉しい。",
            "text_en": "Yeah. But it makes me happy."
        },
        {
            "scene_id": "scene_037",
            "type": "dialogue",
            "character": "player",
            "text_ja": "（...俺も、この人のそばにいたいと思ってる。）",
            "text_en": "(...I want to stay by her side too.)"
        },
        {
            "scene_id": "scene_038",
            "type": "dialogue",
            "text_ja": "すっかり日が暮れるまで、二人は河川敷に並んで座っていた。",
            "text_en": "We sat side by side on the riverside bench until the sun had fully set."
        },
        {
            "scene_id": "scene_039",
            "type": "character_hide",
            "character": "shiori_nagayama"
        },
        {
            "scene_id": "scene_040",
            "type": "image",
            "background": "riverside"
        },
        {
            "scene_id": "scene_041",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.normal",
            "text_ja": "今日も、ありがとう。",
            "text_en": "Thank you again today."
        },
        {
            "scene_id": "scene_042",
            "type": "dialogue",
            "character": "player",
            "text_ja": "こちらこそ。",
            "text_en": "Same here."
        },
        {
            "scene_id": "scene_043",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.relieved",
            "text_ja": "また...誘ってもいい？",
            "text_en": "Can I... invite you again?"
        },
        {
            "scene_id": "scene_044",
            "type": "dialogue",
            "character": "player",
            "text_ja": "もちろんです。",
            "text_en": "Of course."
        },
        {
            "scene_id": "scene_045",
            "type": "dialogue",
            "character": "player",
            "text_ja": "（永山さん。また会いたいな。）",
            "text_en": "(...I want to see her again.)"
        },
        {
            "scene_id": "scene_046",
            "type": "end",
            "flags_set": ["shiori_male_closer_feelings_done", "shiori_nagayama_leave_today"],
            "stat_changes": {
                "affection": 7,
                "intimacy": 7
            }
        }
    ]
}
