{
    "event_id": "shiori_male_dating_night_park",
    "title_ja": "夜の公園",
    "title_en": "Night at the Park",
    "character_id": "shiori_nagayama",
    "scenes": [
        {
            "scene_id": "scene_001",
            "type": "dialogue",
            "text_ja": "夜、詩織さんからメッセージが届いた。",
            "text_en": "Late in the evening, I got a message from Shiori-san."
        },
        {
            "scene_id": "scene_002",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "text_ja": "外の空気吸いたい気分で。公園に来れない？",
            "text_en": "I feel like getting some fresh air. Can you come to the park?"
        },
        {
            "scene_id": "scene_003",
            "type": "dialogue",
            "character": "player",
            "text_ja": "いいですよ。",
            "text_en": "Sure."
        },
        {
            "scene_id": "scene_004",
            "type": "dialogue",
            "character": "player",
            "text_ja": "（よし、公園に行こう。）",
            "text_en": "(Alright, off to the park.)"
        },
        {
            "scene_id": "scene_005",
            "type": "location_change",
            "location": "park"
        },
        {
            "scene_id": "scene_006",
            "type": "dialogue",
            "text_ja": "公園に行くと詩織さんがいた。",
            "text_en": "Shiori-san was already at the park when I arrived."
        },
        {
            "scene_id": "scene_007",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.normal",
            "text_ja": "いいね、夜の公園。なんか落ち着く。",
            "text_en": "There's something nice about the park at night. It's calming."
        },
        {
            "scene_id": "scene_008",
            "type": "dialogue",
            "character": "player",
            "text_ja": "そうですね。",
            "text_en": "Yeah, it is."
        },
        {
            "scene_id": "scene_009",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.normal",
            "text_ja": "今日、ちょっとだけ疲れちゃって。でも{{player.given_name}}くんと会ったら落ち着いた。",
            "text_en": "I was a bit worn out today. But meeting up with you helped me settle down."
        },
        {
            "scene_id": "scene_010",
            "type": "dialogue",
            "character": "player",
            "text_ja": "それはよかった。",
            "text_en": "I'm glad."
        },
        {
            "scene_id": "scene_011",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.smile",
            "text_ja": "{{player.given_name}}くんって、なんか安心するんだよね。いつも。",
            "text_en": "You always make me feel safe somehow, {{player.given_name}}."
        },
        {
            "scene_id": "scene_012",
            "type": "dialogue",
            "character": "player",
            "text_ja": "安心、か。",
            "text_en": "Safe, huh."
        },
        {
            "scene_id": "scene_013",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.smile",
            "text_ja": "いい意味で。",
            "text_en": "In a good way."
        },
        {
            "scene_id": "scene_014",
            "type": "dialogue",
            "character": "player",
            "text_ja": "（...俺も、この人といると安心する。）",
            "text_en": "(...I feel the same way when I'm with her.)"
        },
        {
            "scene_id": "scene_015",
            "type": "dialogue",
            "text_ja": "しばらく、ただそこにいた。言葉はなくても、それで十分だった。",
            "text_en": "For a while, we just stayed there. No words necessary."
        },
        {
            "scene_id": "scene_016",
            "type": "dialogue",
            "text_ja": "...",
            "text_en": "..."
        },
        {
            "scene_id": "scene_017",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.normal",
            "text_ja": "そろそろ帰ろうか。",
            "text_en": "Shall we head back?"
        },
        {
            "scene_id": "scene_018",
            "type": "dialogue",
            "character": "player",
            "text_ja": "うん。",
            "text_en": "Yeah."
        },
        {
            "scene_id": "scene_019",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.smile",
            "text_ja": "今日もありがとう。",
            "text_en": "Thank you again today."
        },
        {
            "scene_id": "scene_020",
            "type": "end",
            "flags_set": ["shiori_nagayama_leave_today"],
            "stat_changes": {
                "affection": 7,
                "intimacy": 7
            }
        }
    ]
}
