        {
            "scene_id": "scene_002",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.smile",
            "text_ja": "あ、{{player.family_name}}くん。",
            "text_en": "Oh, {{player.family_name}}."
        },
        {
            "scene_id": "scene_003",
            "type": "dialogue",
            "character": "player",
            "text_ja": "永山さん。",
            "text_en": "Nagayama-san."
        },
        {
            "scene_id": "scene_004",
            "type": "dialogue",
            "character": "shiori_nagayama",
            "portrait": "casual.normal",
            "text_ja": "最近どう？",
            "text_en": "How have you been?"
